{
  "mcpServers": {
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/path/to/workspace"
      ],
      "env": {},
      "load_prompts": false
    },
    "git": {
      "command": "uvx",
      "args": [
        "mcp-server-git"
      ],
      "env": {},
      "load_prompts": false
    },
    "remote-api": {
      "url": "https://api.example.com/mcp",
      "headers": {
        "Authorization": "Bearer your-api-token-here"
      },
      "request_timeout": 30
    },
    "batch": {
      "command": "uv",
      "args": [
        "run",
        "python",
        "-m",
        "app.mcp_batch.server"
      ],
      "env": {
        "BATCH_JOBS_DIR": ".jobs",
        "RAG_CHUNK_SIZE": "800",
        "RAG_CHUNK_OVERLAP": "200",
        "RAG_CHUNK_MIN_SIZE": "200",
        "BATCH_ENABLE_SAMPLE_JOBS": "false"
      },
      "load_prompts": false
    }
  }
}
