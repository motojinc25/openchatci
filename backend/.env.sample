# ==========================================
# OpenChatCi Backend Configuration
# ==========================================
# HTTPS / TLS (optional, for LAN access with Secure Context)
# Generate certificates with mkcert: mkcert <your-ip> localhost 127.0.0.1
# See: assets/docs/guides/https-lan-setup.md
# APP_HOST=0.0.0.0
APP_HOST=127.0.0.1
# APP_SSL_CERTFILE=.certs/cert.pem
# APP_SSL_KEYFILE=.certs/key.pem
APP_PORT=8000
APP_DEBUG=true
FRONTEND_DIST=../frontend/dist
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Azure CLI Authentication
AZURE_TENANT_ID=your-tenant-id

# Azure OpenAI endpoint (e.g., https://your-resource.openai.azure.com/)
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/

# Azure OpenAI Models (CTR-0069, PRP-0035)
# Comma-separated deployment names. First entry is the default model.
# Single model is valid (e.g., AZURE_OPENAI_MODELS=gpt-4o).
AZURE_OPENAI_MODELS=gpt-5.4,gpt-4o

# Reasoning Effort (CTR-0069, PRP-0035)
# Per-model format: name:effort pairs (only listed models get reasoning).
# Models NOT listed do not send reasoning.effort parameter.
# Valid effort values: low, medium, high, xhigh
# REASONING_EFFORT=o3:high,o4-mini:medium
REASONING_EFFORT=gpt-5.4:medium

# Model Context Window (CTR-0069, PRP-0035)
# Per-model format: name:tokens pairs, comma-separated.
# Single integer fallback applies to all models (e.g., MODEL_MAX_CONTEXT_TOKENS=128000).
# | Model                    | max_context_tokens |
# | gpt-4o / gpt-4o-mini     | 128000             |
# | gpt-4.1 / gpt-4.1-mini   | 1047576            |
# | gpt-5.4 / gpt-5.4-mini   | 1050000            |
# | o3 / o4-mini             | 200000             |
MODEL_MAX_CONTEXT_TOKENS=gpt-5.4:1050000,gpt-4o:128000

# Web Search
WEB_SEARCH_COUNTRY=US

# Session
SESSIONS_DIR=.sessions

# File Upload
UPLOAD_DIR=.uploads

# Speech-to-Text
WHISPER_DEPLOYMENT_NAME=whisper-1

# Coding Tools (CTR-0031, CTR-0032, PRP-0019) - MAF native coding tools
CODING_ENABLED=false
CODING_WORKSPACE_DIR=
CODING_BASH_TIMEOUT=30
CODING_MAX_OUTPUT_CHARS=100000
CODING_MAX_TURNS=50
# Upper bound on bytes returned by file_read in a single call (PRP-0047).
# Files larger than this are truncated with an explicit marker so the
# agent can paginate via offset or narrow the target. Default 1 MiB.
# CODING_FILE_READ_MAX_BYTES=1048576

# DevUI (CTR-0024) - Development debug UI for agent testing
# DevUI binds to APP_HOST (shared with main server)
DEVUI_ENABLED=true
DEVUI_PORT=8080
DEVUI_AUTH_ENABLED=false
DEVUI_AUTH_TOKEN=
DEVUI_TRACING=true
DEVUI_MODE=developer
# DevUI runs in a daemon thread with its own asyncio event loop
# (PRP-0046). MCP tool async contexts are entered by the main FastAPI
# lifespan and the ChromaDB client is thread-bound via SQLite, so
# DevUI excludes both by default. Set to false only if you accept
# the cross-loop risk.
DEVUI_DISABLE_MCP=true
DEVUI_DISABLE_RAG=true

# Text-to-Speech (ElevenLabs)
ELEVENLABS_API_KEY=
TTS_MODEL_ID=eleven_multilingual_v2
TTS_VOICE_ID=

# Agent Skills (file-based SKILL.md packages)
SKILLS_DIR=.skills

# Prompt Templates (file-based JSON templates)
TEMPLATES_DIR=.templates

# Image Generation (Azure OpenAI gpt-image-1.5)
IMAGE_DEPLOYMENT_NAME=gpt-image-1.5

# API Authentication (CTR-0056, CTR-0083, PRP-0045)
# API_KEY is the unified Bearer token for:
#   - External-app access to /v1/responses (CTR-0057, always required)
#   - Write endpoints (image edit, upload, MCP Apps RPC, sessions write,
#     templates write, TTS, STT) when the CLIENT connects from a
#     non-loopback address
# Same-machine clients (127.0.0.1, ::1, localhost) always bypass auth,
# even when APP_HOST=0.0.0.0 for LAN exposure.
# API_KEY=sk-openchatci-your-secret-key-here

# Enforce Bearer API_KEY on write endpoints when bound to a LAN address.
# Default true (fail-closed). Set to false only if an operator explicitly
# accepts unauthenticated LAN exposure.
# APP_REQUIRE_AUTH_ON_LAN=true

# Auth Provider Selection (CTR-0084, PRP-0048)
# Empty (default) -> ApiKeyAuthProvider; preserves CTR-0083 semantics
#                    bit-for-bit (loopback bypass, LAN 401/503 gate).
# null    -> NullAuthProvider (anonymous Identity, no enforcement).
#            Use only when you understand /v1/responses will return 503.
# api_key -> ApiKeyAuthProvider (explicit, same as default).
# msal    -> commercial only (WeDXChatCi).
# Note (PRP-0050 / CTR-0091): the SPA-side counterpart is the
# build-time VITE_AUTH_PROVIDER (frontend/.env.template). In
# commercial deployments AUTH_PROVIDER (backend) and
# VITE_AUTH_PROVIDER (frontend) MUST agree on 'msal' so the OSS
# bundle wraps the chat surface in MsalProvider while the backend
# validates the JWT.
# AUTH_PROVIDER=

# Tenant Extraction Strategy (CTR-0085, PRP-0048)
# none      -> single-tenant, tenant_id = "default" (OSS default).
# jwt_claim -> commercial MSAL; reads TENANT_JWT_CLAIM (default tid)
#              from the decoded JWT claim map surfaced by the AuthProvider.
# subdomain -> reserved name, not implemented yet (Phase 2+).
# api_key   -> reserved name, not implemented yet (Phase 2+).
TENANT_EXTRACTOR=none

# MCP Integration (Claude Desktop-compatible mcp_servers.json)
# Set MCP_CONFIG_FILE to enable. See: https://modelcontextprotocol.io
# MCP_CONFIG_FILE=mcp_servers.json

# MCP Apps (interactive UI in chat via sandboxed iframe)
# Sandbox proxy runs on a separate port for origin isolation.
# Activated automatically when MCP tools declare _meta.ui resources.
# MCP_APPS_SANDBOX_PORT=8081

# Batch Processing MCP Server (Core MCP, add "batch" to mcp_servers.json)
# BATCH_JOBS_DIR is scoped to the batch server process via mcp_servers.json env field.
# BATCH_JOBS_DIR=.jobs
# The Phase-1 sample "sleep" job is gated (PRP-0046). Default false so
# the sample type is hidden from production tool listings. Set true
# in mcp_servers.json env to enable for demos or integration tests.
# BATCH_ENABLE_SAMPLE_JOBS=false

# RAG Pipeline (ChromaDB + Azure OpenAI Embedding)
# Vector database storage directory (shared between Backend and Batch server)
CHROMA_DIR=.chroma
# Collection name for document storage and search
RAG_COLLECTION_NAME=default
# Number of search results returned by rag_search tool
RAG_TOP_K=5
# Azure OpenAI embedding model deployment name
EMBEDDING_DEPLOYMENT_NAME=text-embedding-3-small
# Chunking parameters (characters)
RAG_CHUNK_SIZE=800
RAG_CHUNK_OVERLAP=200
# Trailing-chunk merge threshold (PRP-0047). When the final chunk of a
# page is shorter than this, it is appended to the previous chunk on
# the same page so tiny fragments do not pollute top-k retrieval.
# Unset -> chunker uses RAG_CHUNK_SIZE // 4 (floor 32). 0 disables.
# RAG_CHUNK_MIN_SIZE=200

# CLI Client (CTR-0080, PRP-0041)
# Base URL for CLI client subcommands (default: http://localhost:8000)
# OPENCHATCI_URL=http://localhost:8000
# API key for CLI client authentication (reuses API_KEY if not set)
# OPENCHATCI_API_KEY=
