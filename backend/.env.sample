# ==========================================
# OpenChatCi Backend Configuration
# ==========================================
APP_HOST=127.0.0.1
APP_PORT=8000
APP_DEBUG=true
FRONTEND_DIST=../frontend/dist
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Azure CLI Authentication
AZURE_TENANT_ID=your-tenant-id

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_RESPONSES_DEPLOYMENT_NAME=gpt-5.4

# Reasoning (for supported models: low/medium/high/xhigh, empty to disable)
REASONING_EFFORT=medium

# Model Context Window (CTR-0041, PRP-0023)
# GPT-4o/4o-mini: 128000, GPT-5.4/5.4-mini: 1050000, o3/o4-mini: 200000
MODEL_MAX_CONTEXT_TOKENS=1050000

# Web Search
WEB_SEARCH_COUNTRY=US

# Session
SESSIONS_DIR=.sessions

# File Upload
UPLOAD_DIR=.uploads

# Speech-to-Text
WHISPER_DEPLOYMENT_NAME=whisper-1

# Coding Tools (CTR-0031, CTR-0032, PRP-0019) - MAF native coding tools
CODING_ENABLED=false
CODING_WORKSPACE_DIR=
CODING_BASH_TIMEOUT=30
CODING_MAX_OUTPUT_CHARS=100000
CODING_MAX_TURNS=50

# DevUI (CTR-0024) - Development debug UI for agent testing
# DevUI binds to APP_HOST (shared with main server)
DEVUI_ENABLED=true
DEVUI_PORT=8080
DEVUI_AUTH_ENABLED=false
DEVUI_AUTH_TOKEN=
DEVUI_TRACING=true
DEVUI_MODE=developer

# Text-to-Speech (ElevenLabs)
ELEVENLABS_API_KEY=
TTS_MODEL_ID=eleven_multilingual_v2
TTS_VOICE_ID=

# Agent Skills (file-based SKILL.md packages)
SKILLS_DIR=.skills

# Prompt Templates (file-based JSON templates)
TEMPLATES_DIR=.templates

# Image Generation (Azure OpenAI gpt-image-1.5)
IMAGE_DEPLOYMENT_NAME=gpt-image-1.5
