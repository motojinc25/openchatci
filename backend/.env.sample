# ==========================================
# OpenChatCi Backend Configuration
# ==========================================
# HTTPS / TLS (optional, for LAN access with Secure Context)
# Generate certificates with mkcert: mkcert <your-ip> localhost 127.0.0.1
# See: assets/docs/guides/https-lan-setup.md
# APP_HOST=0.0.0.0
APP_HOST=127.0.0.1
# APP_SSL_CERTFILE=.certs/cert.pem
# APP_SSL_KEYFILE=.certs/key.pem
APP_PORT=8000
APP_DEBUG=true
FRONTEND_DIST=../frontend/dist
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Azure CLI Authentication
AZURE_TENANT_ID=your-tenant-id

# Azure OpenAI endpoint (e.g., https://your-resource.openai.azure.com/)
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/

# Azure OpenAI Models (CTR-0069, PRP-0035)
# Comma-separated deployment names. First entry is the default model.
# Single model is valid (e.g., AZURE_OPENAI_MODELS=gpt-4o).
AZURE_OPENAI_MODELS=gpt-5.4,gpt-4o

# Reasoning Effort (CTR-0069, PRP-0035)
# Per-model format: name:effort pairs (only listed models get reasoning).
# Models NOT listed do not send reasoning.effort parameter.
# Valid effort values: low, medium, high, xhigh
# REASONING_EFFORT=o3:high,o4-mini:medium
REASONING_EFFORT=gpt-5.4:medium

# Model Context Window (CTR-0069, PRP-0035)
# Per-model format: name:tokens pairs, comma-separated.
# Single integer fallback applies to all models (e.g., MODEL_MAX_CONTEXT_TOKENS=128000).
# | Model                    | max_context_tokens |
# | gpt-4o / gpt-4o-mini     | 128000             |
# | gpt-4.1 / gpt-4.1-mini   | 1047576            |
# | gpt-5.4 / gpt-5.4-mini   | 1050000            |
# | o3 / o4-mini             | 200000             |
MODEL_MAX_CONTEXT_TOKENS=gpt-5.4:1050000,gpt-4o:128000

# Web Search
WEB_SEARCH_COUNTRY=US

# Session
SESSIONS_DIR=.sessions

# File Upload
UPLOAD_DIR=.uploads

# Speech-to-Text
WHISPER_DEPLOYMENT_NAME=whisper-1

# Coding Tools (CTR-0031, CTR-0032, PRP-0019) - MAF native coding tools
CODING_ENABLED=false
CODING_WORKSPACE_DIR=
CODING_BASH_TIMEOUT=30
CODING_MAX_OUTPUT_CHARS=100000
CODING_MAX_TURNS=50

# DevUI (CTR-0024) - Development debug UI for agent testing
# DevUI binds to APP_HOST (shared with main server)
DEVUI_ENABLED=true
DEVUI_PORT=8080
DEVUI_AUTH_ENABLED=false
DEVUI_AUTH_TOKEN=
DEVUI_TRACING=true
DEVUI_MODE=developer

# Text-to-Speech (ElevenLabs)
ELEVENLABS_API_KEY=
TTS_MODEL_ID=eleven_multilingual_v2
TTS_VOICE_ID=

# Agent Skills (file-based SKILL.md packages)
SKILLS_DIR=.skills

# Prompt Templates (file-based JSON templates)
TEMPLATES_DIR=.templates

# Image Generation (Azure OpenAI gpt-image-1.5)
IMAGE_DEPLOYMENT_NAME=gpt-image-1.5

# OpenAI Compatible API (exposes /v1/responses on main server)
# Set API_KEY to enable. External apps use this as Bearer token.
# API_KEY=sk-openchatci-your-secret-key-here

# MCP Integration (Claude Desktop-compatible mcp_servers.json)
# Set MCP_CONFIG_FILE to enable. See: https://modelcontextprotocol.io
# MCP_CONFIG_FILE=mcp_servers.json

# MCP Apps (interactive UI in chat via sandboxed iframe)
# Sandbox proxy runs on a separate port for origin isolation.
# Activated automatically when MCP tools declare _meta.ui resources.
# MCP_APPS_SANDBOX_PORT=8081

# Batch Processing MCP Server (Core MCP, add "batch" to mcp_servers.json)
# BATCH_JOBS_DIR is scoped to the batch server process via mcp_servers.json env field.
# BATCH_JOBS_DIR=.jobs

# RAG Pipeline (ChromaDB + Azure OpenAI Embedding)
# Vector database storage directory (shared between Backend and Batch server)
CHROMA_DIR=.chroma
# Collection name for document storage and search
RAG_COLLECTION_NAME=default
# Number of search results returned by rag_search tool
RAG_TOP_K=5
# Azure OpenAI embedding model deployment name
EMBEDDING_DEPLOYMENT_NAME=text-embedding-3-small
# Chunking parameters (characters)
RAG_CHUNK_SIZE=800
RAG_CHUNK_OVERLAP=200

# CLI Client (CTR-0080, PRP-0041)
# Base URL for CLI client subcommands (default: http://localhost:8000)
# OPENCHATCI_URL=http://localhost:8000
# API key for CLI client authentication (reuses API_KEY if not set)
# OPENCHATCI_API_KEY=
